```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/

# Dependencies
node_modules/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db

# Build outputs
build/
dist/
*.egg-info/

# Testing
.pytest_cache/
.mypy_cache/

# Zip and compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```